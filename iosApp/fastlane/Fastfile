require File.expand_path("xcconfig_helper", __dir__)

extend XcconfigHelper

def required_xcconfig_value(key)
  value = xcconfig_value(key)
  UI.user_error!("Missing required Fastlane setting: #{key}") if value.to_s.empty?
  value
end

def release_provisioning_profile
  required_xcconfig_value("SIGNING_RELEASE_PROVISIONING_PROFILE_SPECIFIER")
end

def app_bundle_identifier
  required_xcconfig_value("APP_BUNDLE_IDENTIFIER")
end

def signing_development_team
  required_xcconfig_value("SIGNING_DEVELOPMENT_TEAM")
end

lane :test do
  run_tests
end

lane :build do
  setup_ci if ENV['CI']
  app_store_connect_api_key(
    key_id: ENV['APPLE_API_KEY_ID'],
    issuer_id: ENV['APPLE_API_ISSUER_ID'],
    key_content: ENV['APPLE_API_KEY_CONTENT'],
    is_key_content_base64: true
  )
  import_certificate(
    certificate_path: "cert.p12",
    certificate_password: ENV['APPLE_CERT_PASSWORD'],
    keychain_name: "fastlane_tmp_keychain"
  )
  profile_path = get_provisioning_profile(
    app_identifier: app_bundle_identifier,
    team_id: signing_development_team,
    provisioning_name: release_provisioning_profile,
    readonly: true
  )
  update_project_provisioning(
    build_configuration: "Release",
    profile: profile_path,
    target_filter: "iosApp"
  )
  build_app(
    configuration: "Release"
  )
end


lane :deploy do
  setup_ci if ENV['CI']
  app_store_connect_api_key(
    key_id: ENV['APPLE_API_KEY_ID'],
    issuer_id: ENV['APPLE_API_ISSUER_ID'],
    key_content: ENV['APPLE_API_KEY_CONTENT'],
    is_key_content_base64: true
  )
  import_certificate(
    certificate_path: "cert.p12",
    certificate_password: ENV['APPLE_CERT_PASSWORD'],
    keychain_name: "fastlane_tmp_keychain"
  )
  profile_path = get_provisioning_profile(
    app_identifier: app_bundle_identifier,
    team_id: signing_development_team,
    provisioning_name: release_provisioning_profile,
    readonly: true
  )
  increment_build_number(
    build_number: latest_testflight_build_number + 1
  )
  update_project_provisioning(
    build_configuration: "Release",
    profile: profile_path,
    target_filter: "iosApp"
  )
  build_app(
    configuration: "Release",
    export_method: "app-store"
  )
  upload_to_testflight(
    skip_waiting_for_build_processing: true
  )
end
